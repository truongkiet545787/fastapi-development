[Unit]
Description=Gunicorn instance to serve FastAPI
After=network.target

[Service]
User=fastapi
Group=fastapi
WorkingDirectory=/home/fastapi/fastapi-development
Environment="PATH=/home/fastapi/fastapi-development/venv/bin"
ExecStart=/home/fastapi/fastapi-development/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker app.main:app -b 0.0.0.0:8000

[Install]
WantedBy=multi-user.target
